{
  "name": "@omnixys/contracts",
  "version": "1.2.0",
  "type": "module",
  "private": false,
  "packageManager": "pnpm@9.12.0",
  "description": "Authentication utilities, guards, decorators and JWT helpers for Omnixys microservices.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "patch": "pnpm version patch",
    "release": "semantic-release",
    "lint": "biome lint",
    "format": "biome format --write",
    "lint:fix": "biome lint . --write",
    "check": "biome check .",
    "check:fix": "biome check . --write"
